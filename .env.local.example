# Optimizely SaaS Content Graph
# Find these in your Optimizely SaaS CMS project settings
OPTIMIZELY_GRAPH_SINGLE_KEY=your_single_key_here
OPTIMIZELY_GRAPH_APP_KEY=your_app_key_here
OPTIMIZELY_GRAPH_SECRET=your_secret_here
OPTIMIZELY_GRAPH_GATEWAY=https://cg.optimizely.com

# Auth secret for session signing (generate a random string)
AUTH_SECRET=your_random_secret_here

# Calculators page — email lead capture
# Set this to your CRM / marketing API endpoint
NEXT_PUBLIC_LEAD_CAPTURE_API_URL=https://your-api.example.com/leads
